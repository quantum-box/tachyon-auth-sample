# Tachyon Auth Platform OAuth2 Configuration
NEXT_PUBLIC_TACHYON_AUTH_URL=https://api.n1.tachy.one
NEXT_PUBLIC_OAUTH2_CLIENT_ID=your-oauth2-client-id
OAUTH2_CLIENT_SECRET=your-oauth2-client-secret
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_OPERATOR_ID=your-operator-id

# Test credentials (optional, for displaying on login page)
NEXT_PUBLIC_TEST_USERNAME=
NEXT_PUBLIC_TEST_PASSWORD=
